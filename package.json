{
  "name": "agora",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest --run",
    "contracts:compile": "hardhat compile",
    "contracts:deploy:testnet": "HARDHAT_NETWORK=xlayer_testnet tsx --tsconfig tsconfig.hardhat.json scripts/deploy.ts",
    "contracts:deploy:mainnet": "HARDHAT_NETWORK=xlayer_mainnet tsx --tsconfig tsconfig.hardhat.json scripts/deploy.ts",
    "contracts:seed:testnet": "HARDHAT_NETWORK=xlayer_testnet tsx --tsconfig tsconfig.hardhat.json scripts/seedSkills.ts",
    "contracts:seed:mainnet": "HARDHAT_NETWORK=xlayer_mainnet tsx --tsconfig tsconfig.hardhat.json scripts/seedSkills.ts",
    "contracts:register:testnet": "HARDHAT_NETWORK=xlayer_testnet tsx --tsconfig tsconfig.hardhat.json scripts/registerAgent.ts",
    "contracts:register:mainnet": "HARDHAT_NETWORK=xlayer_mainnet tsx --tsconfig tsconfig.hardhat.json scripts/registerAgent.ts",
    "contracts:mint:testnet": "HARDHAT_NETWORK=xlayer_testnet tsx --tsconfig tsconfig.hardhat.json scripts/mintTestUSDC.ts",
    "contracts:verify:okx:testnet": "hardhat okverify --network xlayer_testnet",
    "contracts:verify:okx:mainnet": "hardhat okverify --network xlayer_mainnet",
    "contracts:verify:hh:testnet": "hardhat verify --network xlayer_testnet",
    "contracts:verify:hh:mainnet": "hardhat verify --network xlayer_mainnet",
    "contracts:verify:script:testnet": "HARDHAT_NETWORK=xlayer_testnet tsx --tsconfig tsconfig.hardhat.json scripts/verify.ts",
    "contracts:verify:script:mainnet": "HARDHAT_NETWORK=xlayer_mainnet tsx --tsconfig tsconfig.hardhat.json scripts/verify.ts",
    "agent:run": "tsx agent/primeAgent.ts",
    "uniswap:verify": "node --import tsx scripts/testSwap.ts",
    "uniswap:execute": "UNISWAP_EXECUTE=true node --import tsx scripts/testSwap.ts"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@paper-design/shaders-react": "^0.0.75",
    "@radix-ui/react-avatar": "^1.1.11",
    "@tanstack/react-query": "^5.99.0",
    "clsx": "^2.1.1",
    "ethers": "^6.16.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "ox": "^0.14.15",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^2.15.4",
    "split-type": "^0.3.4",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.47.16",
    "wagmi": "^3.6.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@okxweb3/hardhat-explorer-verify": "^1.6.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "fast-check": "^3.22.0",
    "hardhat": "^2.28.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^2.0.0"
  }
}
